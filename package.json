{
  "name": "@betterhyq/betterhyq",
  "version": "0.0.1",
  "author": "betterhyq <betterhyq@qq.com>",
  "scripts": {
    "build": "modern build",
    "dev": "modern dev",
    "lint": "biome check --write --files-ignore-unknown=true",
    "new": "modern new",
    "reset": "npx rimraf ./**/node_modules",
    "serve": "modern serve",
    "start": "modern start",
    "upgrade": "modern upgrade"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "@douyinfe/semi-ui": "2.90.13",
    "@modern-js/plugin-tailwindcss": "2.70.4",
    "@modern-js/runtime": "2.70.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@douyinfe/semi-rspack-plugin": "2.38.3-alpha.2-patch-select-max",
    "@modern-js/app-tools": "2.70.4",
    "@modern-js/tsconfig": "2.70.4",
    "@types/jest": "29.2.6",
    "@types/node": "18.11.19",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "lint-staged": "15.4.3",
    "rimraf": "6.1.2",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.25.0"
}
